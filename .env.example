# Turso (remote libSQL)
# Create: `turso db create <name>` → copy URL from `turso db show <name> --url`
# Token:  `turso db tokens create <name>`
TURSO_DATABASE_URL=libsql://<db-name>-<org>.turso.io
TURSO_AUTH_TOKEN=


# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Clerk Routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding/name

# Hetzner Cloud (Phase 2)
# Token is project-scoped in Hetzner — resources go to whichever project the token belongs to
HETZNER_API_TOKEN=

# Admin (Phase 2)
ADMIN_API_KEY=

# Credentials encryption (Phase 4)
# Generate with: openssl rand -base64 32
# Used to envelope-encrypt rootCredential and gatewayToken in assistant_credentials.
CREDENTIALS_MASTER_KEY=

# Tailscale (Phase 4)
# API key from https://login.tailscale.com/admin/settings/keys
# Used to verify user-supplied auth keys before provisioning.
TAILSCALE_API_KEY=
TAILSCALE_TAILNET=

# Cloudflare DNS (Phase 3)
# API token scoped to Zone.DNS:Edit on the target zone
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_BASE_DOMAIN=

# OpenRouter (Phase 4)
OPENROUTER_API_KEY=

# Stripe (Phase 5)
# Test-mode keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook signing secret. For local dev, run:
#   stripe listen --forward-to localhost:3000/api/webhooks/stripe
# and copy the printed `whsec_...` value here.
# In production, use the secret from the webhook endpoint configured in
# the Stripe Dashboard (Developers → Webhooks).
STRIPE_WEBHOOK_SECRET=whsec_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Feature flags (set to "true" to enable)
NEXT_PUBLIC_FF_ORGS=false
